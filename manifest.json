{
  "manifest_version": 3,
  "name": "StreamRatings",
  "version": "1.0.0",
  "description": "Overlay IMDb & Rotten Tomatoes ratings on Netflix, Prime Video, Hotstar, SonyLIV, and Zee5 cards. Grey out low-rated titles and save favourites to a local watchlist with genre and platform filters.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.primevideo.com/*",
    "https://www.hotstar.com/*",
    "https://www.sonyliv.com/*",
    "https://www.zee5.com/*",
    "https://www.omdbapi.com/*",
    "https://www.rottentomatoes.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["content/netflix.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.primevideo.com/*"],
      "js": ["content/primevideo.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.hotstar.com/*"],
      "js": ["content/hotstar.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.sonyliv.com/*"],
      "js": ["content/sonyliv.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.zee5.com/*"],
      "js": ["content/zee5.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "StreamRatings Settings"
  },
  "web_accessible_resources": [
    {
      "resources": ["watchlist/watchlist.html", "watchlist/watchlist.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
